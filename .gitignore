__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

logs/
checkpoints/

# skills_data/ holds crystallized skill checkpoints -- small (~50 KB
# total) and required for transfer-arm runs, so we track the .pt files
# there explicitly. Everything else under skills_data/ stays ignored.
skills_data/*
!skills_data/*.pt

*.pt
!ragnarok/**/*.py
!skills_data/*.pt

.env
.venv/
venv/
venv310/
venv311/
.pytest_cache/
